# Build Container with Java,Ruby,GIT and perl

# Create a base image with common OS utilities needed in all the images
FROM ubuntu:18.04 as base
SHELL ["/bin/bash", "-c"]
RUN apt-get -qq update && \
    apt-get -qq install -y \
	curl \
	wget \
	openssl \
	perl \
	git \
	build-essential

RUN apt-get install openjdk-8-jdk -y
RUN apt-get install iputils-ping -y
RUN apt-get install zip -y
RUN apt-get install libxml2-dev libxslt-dev -y

#RUN apt-get install software-properties-common -y
#RUN add-apt-repository ppa:fkrull/deadsnakes

RUN apt-get update
RUN apt-get install python3 -y
RUN apt-get install python3-pip -y



RUN ln -s /usr/bin/python3.6 /usr/bin/python && \
    ln -s /usr/bin/pip3 /usr/bin/pip

#RUN pip install --upgrade pip

RUN python -m pip install requests
RUN python -m pip install msgpack
RUN python -m pip install lxml

RUN pip install requests
RUN pip install lxml
